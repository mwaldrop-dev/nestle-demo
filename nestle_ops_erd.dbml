Table alert_escalation {
  escalation_id int [pk]
  alert_id int [not null]
  escalation_level int [not null]
  escalated_to int [not null]
  escalated_time timestamp [not null]
  reason varchar
}

// ─── DOMAIN 10: KPIs, ANALYTICS & DEMAND ───

Table kpi_definition {
  kpi_id int [pk]
  kpi_name varchar [not null]
  kpi_code varchar [not null]
  domain varchar
  description text
  uom_id int
  aggregation varchar
  direction varchar
}

Table kpi_target {
  target_id int [pk]
  kpi_id int [not null]
  site_id int
  period_id int [not null]
  target_value decimal [not null]
  stretch_value decimal
  floor_value decimal
}

Table kpi_measurement {
  measurement_id int [pk]
  kpi_id int [not null]
  site_id int
  measured_date date [not null]
  measured_value decimal [not null]
  period_id int
}

Table dashboard_config {
  config_id int [pk]
  dashboard_name varchar [not null]
  owner_id int [not null]
  layout_json text
  is_default boolean [default: false]
  created_date timestamp [not null]
  modified_date timestamp
}

Table customer {
  customer_id int [pk]
  customer_name varchar [not null]
  customer_code varchar [not null]
  customer_type varchar
  country_id int [not null]
  region_id int
  credit_limit decimal
  payment_terms varchar
  status varchar [default: 'active']
}

Table sales_order {
  order_id int [pk]
  order_number varchar [not null]
  customer_id int [not null]
  order_date timestamp [not null]
  requested_date date
  ship_to_site int
  total_amount decimal
  currency_id int
  priority varchar
  status varchar [default: 'confirmed']
}

Table sales_order_line {
  order_line_id int [pk]
  order_id int [not null]
  product_id int [not null]
  variant_id int
  quantity decimal [not null]
  uom_id int [not null]
  unit_price decimal
  line_total decimal
  line_number int [not null]
}

Table demand_forecast {
  forecast_id int [pk]
  forecast_name varchar [not null]
  period_id int [not null]
  created_by int
  created_date timestamp [not null]
  forecast_type varchar
  status varchar [default: 'draft']
}

Table forecast_line {
  forecast_line_id int [pk]
  forecast_id int [not null]
  product_id int [not null]
  site_id int
  region_id int
  forecast_qty decimal [not null]
  uom_id int [not null]
  confidence decimal
}

