// ─── DOMAIN 1: MASTER DATA & REFERENCE ───

Table region {
  region_id int [pk]
  region_name varchar [not null]
  region_code varchar [not null]
  parent_region_id int
  is_active boolean [default: true]
}

Table country {
  country_id int [pk]
  country_name varchar [not null]
  iso_code_2 char [not null]
  iso_code_3 char [not null]
  region_id int [not null]
  currency_code varchar [not null]
}

Table currency {
  currency_id int [pk]
  currency_code char [not null]
  currency_name varchar [not null]
  symbol varchar
  exchange_rate decimal
  rate_date date
}

Table unit_of_measure {
  uom_id int [pk]
  uom_code varchar [not null]
  uom_name varchar [not null]
  uom_type varchar [not null]
  base_factor decimal [default: 1.0]
}

Table fiscal_period {
  period_id int [pk]
  period_name varchar [not null]
  fiscal_year int [not null]
  quarter int [not null]
  start_date date [not null]
  end_date date [not null]
  is_closed boolean [default: false]
}

Table brand {
  brand_id int [pk]
  brand_name varchar [not null]
  brand_code varchar [not null]
  parent_brand_id int
  market_segment varchar
}

Table product_category {
  category_id int [pk]
  category_name varchar [not null]
  category_code varchar [not null]
  parent_category_id int
  level int [not null, default: 1]
}

Table product {
  product_id int [pk]
  product_name varchar [not null]
  sku varchar [not null]
  brand_id int [not null]
  category_id int [not null]
  base_uom_id int [not null]
  shelf_life_days int
  is_cold_chain boolean [default: false]
  min_temp_celsius decimal
  max_temp_celsius decimal
  status varchar [default: 'active']
}

Table product_variant {
  variant_id int [pk]
  product_id int [not null]
  variant_name varchar [not null]
  variant_sku varchar [not null]
  net_weight decimal
  gross_weight decimal
  weight_uom_id int
  barcode varchar
}

Table ingredient {
  ingredient_id int [pk]
  ingredient_name varchar [not null]
  ingredient_code varchar [not null]
  category varchar
  is_allergen boolean [default: false]
  allergen_type varchar
  country_of_origin int
  is_organic boolean [default: false]
  shelf_life_days int
}

Table product_ingredient {
  product_ingredient_id int [pk]
  product_id int [not null]
  ingredient_id int [not null]
  percentage decimal
  is_primary boolean [default: false]
  sequence_order int
}

Table packaging_type {
  packaging_type_id int [pk]
  type_name varchar [not null]
  material varchar
  is_recyclable boolean [default: false]
  weight_grams decimal
}

Table regulatory_standard {
  standard_id int [pk]
  standard_name varchar [not null]
  standard_code varchar [not null]
  issuing_body varchar
  country_id int
  category varchar
}

Table certification_type {
  cert_type_id int [pk]
  cert_name varchar [not null]
  cert_code varchar [not null]
  issuing_body varchar
  validity_months int
  standard_id int
}

